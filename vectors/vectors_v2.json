        ]
      ],
      "s_in": [
        "333333333333333334",
        "333333333333333333",
        "333333333333333333"
      ],
      "N": 1,
      "s_out": [
        "333333333333333332",
        "333333333333333331",
        "333333333333333331"
      ],
      "expect": "reject",
      "note": "GREASE. version=3 is unknown to a v2 implementation. Unknown version MUST reject cleanly, never crash. Payload is otherwise n1-uniform's valid claim to prove the reject is the version gate, not the math."
    },
    {
      "name": "grease-n-too-large",
      "version": 2,
      "M": [
        [
          "700000000000000000",
          "250000000000000000",
          "50000000000000000"
        ],
        [
