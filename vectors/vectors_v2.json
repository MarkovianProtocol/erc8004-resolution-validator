{
  "$schema": "https://markovianprotocol.com/schemas/resolve-vectors/v2",
  "profile": "markovian.resolve.v2",
  "description": "Conformance test vectors for the Markovian integer work function (WAD fixed-point, exact equality \u2014 no floats, no tolerance). A conformant implementation derives s_in from 'hash' when present (and MUST get the listed s_in), runs N plain iterations of the per-element-floor matvec under SPEC_V2.md, and reproduces every 'expect'. All values are decimal strings of WAD-scaled (1e18) unsigned integers.",
  "wad": "1000000000000000000",
  "n_max": 1048576,
  "genesis_m_v2": [
    [
      "700000000000000000",
      "250000000000000000",
      "50000000000000000"
    ],
    [
      "100000000000000000",
      "750000000000000000",
      "150000000000000000"
    ],
    [
      "200000000000000000",
      "150000000000000000",
      "650000000000000000"
    ]
  ],
  "derivation": "a,b,c = first 24 hash bytes as 3 big-endian uint64; s[i] = x_i*WAD // (a+b+c); remainder WAD - sum(s) (0..2) added to s[0]; a+b+c == 0 => reject.",
  "iteration": "s'[i] = (M[i][0]*s[0])//WAD + (M[i][1]*s[1])//WAD + (M[i][2]*s[2])//WAD  \u2014 per-element floor, then sum; N plain iterations; no renormalization; exponentiation-by-squaring is NON-conformant (floor rounding is non-associative).",
  "comparator": "exact equality of the final 3-vector. No tolerance.",
  "source": "Derivation hashes are live MKV chain block hashes (heights 2440, 2439, chain.db 2026-07-17) plus deterministic sha256 constructions noted per vector.",
  "vectors": [
    {
      "name": "n0-identity",
      "version": 2,
      "M": [
        [
          "700000000000000000",
          "250000000000000000",
          "50000000000000000"
        ],
        [
          "100000000000000000",
          "750000000000000000",
          "150000000000000000"
        ],
        [
          "200000000000000000",
          "150000000000000000",
          "650000000000000000"
        ]
      ],
      "s_in": [
        "333333333333333334",
        "333333333333333333",
        "333333333333333333"
      ],
      "N": 0,
      "s_out": [
        "333333333333333334",
        "333333333333333333",
        "333333333333333333"
      ],
      "expect": true,
      "note": "N=0 is the identity: s_out == s_in. The uniform vector is WAD//3 per component with the 1-unit remainder on index 0, sum exactly WAD."
    },
    {
      "name": "n1-uniform",
      "version": 2,
      "M": [
        [
          "700000000000000000",
          "250000000000000000",
          "50000000000000000"
        ],
        [
          "100000000000000000",
          "750000000000000000",
          "150000000000000000"
        ],
        [
          "200000000000000000",
          "150000000000000000",
          "650000000000000000"
        ]
      ],
      "s_in": [
        "333333333333333334",
        "333333333333333333",
        "333333333333333333"
      ],
      "N": 1,
      "s_out": [
        "333333333333333332",
        "333333333333333331",
        "333333333333333331"
      ],
      "expect": true,
      "note": "One iteration from uniform. GENESIS_M v2 rows each sum to exactly WAD, so this stays near-uniform; per-element floor is the only loss."
    },
    {
      "name": "n2-live-block-2440",
      "version": 2,
      "M": [
        [
          "700000000000000000",
          "250000000000000000",
          "50000000000000000"
        ],
        [
          "100000000000000000",
          "750000000000000000",
          "150000000000000000"
        ],
        [
          "200000000000000000",
          "150000000000000000",
          "650000000000000000"
        ]
      ],
      "hash": "0x00031ceb126f4ee8993f1ebb4c6e86039ddfc164af6d933bf964763e4db8ee29",
      "s_in": [
        "39083017773260",
        "492543951467133045",
        "507416965515093695"
      ],
      "N": 2,
      "s_out": [
        "235540562006255023",
        "409553297508806620",
        "358947285350887599"
      ],
      "expect": true,
      "note": "s_in derived from live MKV block 2440 hash (first 24 bytes as 3 big-endian uint64, floor-normalized, remainder 1 to index 0). N=2."
    },
    {
      "name": "n1000-live-difficulty",
      "version": 2,
      "M": [
        [
          "700000000000000000",
          "250000000000000000",
          "50000000000000000"
        ],
        [
          "100000000000000000",
