        "333333333333333333"
      ],
      "N": 65536,
      "s_out": [
        "333333333333333320",
        "333333333333333320",
        "333333333333333320"
      ],
      "expect": true,
      "note": "Large-N case, 2^16 plain iterations. N up to N_MAX=2^20 is accepted; 2^16 keeps the vector executable inside one EVM block."
    },
    {
      "name": "derive-remainder-2",
      "version": 2,
      "M": [
        [
          "700000000000000000",
          "250000000000000000",
          "50000000000000000"
        ],
        [
          "100000000000000000",
          "750000000000000000",
          "150000000000000000"
        ],
        [
          "200000000000000000",
          "150000000000000000",
          "650000000000000000"
        ]
      ],
      "hash": "0xb569ae79fd61a1d48ce8afeea68ae4442c55c050ca6ba1928fd4bb5bb7108001",
      "s_in": [
        "494775655921860724",
        "384307520581382277",
        "120916823496756999"
      ],
      "N": 1,
      "s_out": [
        "448465680465485924",
        "355845729552736328",
        "235197194544471534"
      ],
      "expect": true,
      "note": "Derivation remainder rule firing at its maximum: the three floors leave r=2 WAD-units, both added to index 0. At least one component's fractional part exceeds 1/2, so naive nearest-rounding would produce a different vector: floor + remainder-to-index-0 is normative. Hash is sha256('markovian.resolve.v2 remainder vector 1')."
    },
    {
      "name": "wrong-output-one-unit",
      "version": 2,
      "M": [
        [
          "700000000000000000",
          "250000000000000000",
          "50000000000000000"
        ],
        [
          "100000000000000000",
          "750000000000000000",
          "150000000000000000"
        ],
        [
          "200000000000000000",
          "150000000000000000",
          "650000000000000000"
        ]
      ],
      "hash": "0x00031ceb126f4ee8993f1ebb4c6e86039ddfc164af6d933bf964763e4db8ee29",
      "s_in": [
        "39083017773260",
        "492543951467133045",
        "507416965515093695"
      ],
      "N": 2,
      "s_out": [
        "235540562006255023",
        "409553297508806620",
        "358947285350887600"
      ],
      "expect": false,
      "note": "n2-live-block-2440's correct output with the last component off by ONE WAD-unit (1e-18). v1's np.allclose(atol=1e-9) accepts this forgery; v2's exact-equality comparator returns false. This vector is the reason the profile exists."
    },
    {
      "name": "grease-wrong-sum",
      "version": 2,
      "M": [
        [
          "700000000000000000",
          "250000000000000000",
          "50000000000000000"
        ],
        [
          "100000000000000000",
          "750000000000000000",
          "150000000000000000"
        ],
        [
          "200000000000000000",
          "150000000000000000",
          "650000000000000000"
        ]
      ],
      "s_in": [
        "333333333333333333",
        "333333333333333333",
        "333333333333333333"
      ],
      "N": 1,
      "s_out": [
        "333333333333333332",
        "333333333333333331",
        "333333333333333331"
      ],
      "expect": "reject",
      "note": "GREASE. s_in sums to WAD-1. A state vector MUST sum to exactly WAD; a conformant implementation rejects cleanly (no math, no crash), never silently normalizes."
    },
    {
      "name": "grease-component-gt-wad",
      "version": 2,
      "M": [
        [
          "700000000000000000",
          "250000000000000000",
          "50000000000000000"
        ],
        [
          "100000000000000000",
          "750000000000000000",
          "150000000000000000"
        ],
        [
          "200000000000000000",
          "150000000000000000",
          "650000000000000000"
        ]
      ],
      "s_in": [
        "333333333333333334",
        "333333333333333333",
        "333333333333333333"
      ],
      "N": 1,
      "s_out": [
        "1000000000000000001",
        "0",
        "0"
      ],
      "expect": "reject",
      "note": "GREASE. Claimed output component is WAD+1. No reachable state has a component above WAD (rows sum to WAD, so the max component never grows); a claim outside the domain is malformed -> reject, not false."
    },
    {
      "name": "grease-unknown-version",
      "version": 3,
      "M": [
        [
          "700000000000000000",
          "250000000000000000",
          "50000000000000000"
        ],
